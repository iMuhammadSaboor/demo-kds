# ===========================================================
# Demo KDS — environment config
# Copy this file to `.env` and fill in your own values.
# Load it with:  node --env-file=.env server.mjs
# ===========================================================

# Port the local server listens on. Default 4000.
PORT=4000

# ---- Square -----------------------------------------------

# "sandbox" while you're testing, "production" when you go live
# with the cafe's real Square account.
SQUARE_ENV=sandbox

# Your Square sandbox access token. Grab it from:
#   https://developer.squareup.com/apps → your app → Sandbox tab → Credentials
# Sandbox tokens start with "EAAA...". They're long (~80 chars).
SQUARE_TOKEN=

# The webhook signature key. In the dev dashboard:
#   your app → Webhooks → Subscriptions → your subscription → Signature Key
# Used to verify webhook POSTs actually came from Square.
SQUARE_SIG_KEY=

# The full public URL of your webhook endpoint. When using ngrok:
#   https://abcd-1234.ngrok-free.app/square/webhook
# Must match EXACTLY what you register in the Square dashboard —
# signature verification hashes this URL + the request body.
SQUARE_WEBHOOK_URL=
